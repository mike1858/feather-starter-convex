// Test Matrix: {{name}} mutations
// | # | Mutation         | State                    | What to verify                                               |
// |---|------------------|--------------------------|--------------------------------------------------------------|
{{#if operations.create}}
// | 1 | create           | with defaults            | required fields, defaults, userId set                        |
// | 2 | create           | with all optional fields | optional fields persisted                                    |
// | 3 | create           | unauthenticated          | no record inserted                                           |
{{/if}}
{{#if operations.update}}
// | 4 | update           | single field             | field changed, others untouched                              |
// | 5 | update           | record not found         | throws "not found"                                           |
// | 6 | update           | unauthenticated          | no change                                                    |
{{/if}}
{{#if operations.delete}}
{{#if behaviors.softDelete}}
// | 7 | remove           | existing record          | deletedAt set                                                |
{{else}}
// | 7 | remove           | existing record          | record deleted                                               |
{{/if}}
// | 8 | remove           | unauthenticated          | record not deleted                                           |
{{/if}}
{{#each fields}}
{{#if this.transitions}}
// | 9 | update{{pascalCase @key}} | valid transition         | {{@key}} changed                                    |
// |10 | update{{pascalCase @key}} | invalid transition       | throws "Invalid status transition"                  |
// |11 | update{{pascalCase @key}} | record not found         | throws "not found"                                  |
// |12 | update{{pascalCase @key}} | unauthenticated          | {{@key}} unchanged                                  |
{{/if}}
{{/each}}
{{#if behaviors.assignable}}
// |13 | assign           | to another user          | assigneeId set, visibility=shared                            |
// |14 | assign           | to creator (self)        | assigneeId set, visibility stays private                     |
// |15 | assign           | unassign                 | assigneeId cleared, visibility=shared                        |
// |16 | assign           | record not found         | throws "not found"                                           |
// |17 | assign           | unauthenticated          | no change                                                    |
{{/if}}
{{#if behaviors.orderable}}
// |18 | reorder          | valid position           | position updated                                             |
// |19 | reorder          | unauthenticated          | position unchanged                                           |
{{/if}}


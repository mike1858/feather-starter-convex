{{!-- @generated-start table-view --}}
import { useState, useMemo, useCallback } from "react";
import {
  ChevronUp,
  ChevronDown,
  ChevronLeft,
  ChevronRight,
  ChevronsUpDown,
  Pencil,
  Trash2,
  Check,
  X,
  ExternalLink,
  Table2,
} from "lucide-react";
import { Button } from "@/ui/button";
import { {{pascalCase name}}EmptyState } from "./{{pascalCase name}}EmptyState";

{{!-- Column width mapping --}}
const WIDTH_MAP: Record<string, number> = {
  xs: 80,
  sm: 120,
  md: 200,
  lg: 300,
  xl: 400,
};

interface {{pascalCase name}}TableViewProps {
  items: Array<Record<string, unknown>>;
  isLoading: boolean;
  totalCount?: number;
  onRowClick?: (item: Record<string, unknown>) => void;
  onEdit?: (item: Record<string, unknown>) => void;
  onDelete?: (item: Record<string, unknown>) => void;
}

type SortDirection = "asc" | "desc";

export function {{pascalCase name}}TableView({
  items,
  isLoading,
  totalCount = 0,
  onRowClick,
  onEdit,
  onDelete,
}: {{pascalCase name}}TableViewProps) {
  // Sorting state
  const [sortColumn, setSortColumn] = useState<string | null>(null);
  const [sortDirection, setSortDirection] = useState<SortDirection>("asc");

  // Pagination state
  const storedPageSize =
    typeof window !== "undefined"
      ? Number(localStorage.getItem("{{name}}-page-size")) || {{#if views.table.pageSize}}{{views.table.pageSize}}{{else}}20{{/if}}
      : {{#if views.table.pageSize}}{{views.table.pageSize}}{{else}}20{{/if}};
  const [pageSize, setPageSize] = useState(storedPageSize);
  const [currentPage, setCurrentPage] = useState(1);

  {{#if views.table.groupBy}}
  // Grouping state
  const [collapsedGroups, setCollapsedGroups] = useState<Set<string>>(new Set());

  const toggleGroup = useCallback((groupKey: string) => {
    setCollapsedGroups((prev) => {
      const next = new Set(prev);
      if (next.has(groupKey)) {
        next.delete(groupKey);
      } else {
        next.add(groupKey);
      }
      return next;
    });
  }, []);
  {{/if}}

  // Sort handler
  const handleSort = useCallback((column: string) => {
    setSortColumn((prev) => {
      if (prev === column) {
        setSortDirection((d) => {
          if (d === "asc") return "desc";
          // Reset sort
          setSortColumn(null);
          return "asc";
        });
        return column;
      }
      setSortDirection("asc");
      return column;
    });
  }, []);

  // Client-side sorting
  const sortedItems = useMemo(() => {
    if (!sortColumn) return items;
    return [...items].sort((a, b) => {
      const aVal = a[sortColumn];
      const bVal = b[sortColumn];
      if (aVal == null && bVal == null) return 0;
      if (aVal == null) return 1;
      if (bVal == null) return -1;
      const cmp = String(aVal).localeCompare(String(bVal), undefined, { numeric: true });
      return sortDirection === "asc" ? cmp : -cmp;
    });
  }, [items, sortColumn, sortDirection]);

  // Pagination
  const totalPages = Math.ceil((totalCount || sortedItems.length) / pageSize);
  const startIdx = (currentPage - 1) * pageSize;
  const endIdx = startIdx + pageSize;
  const paginatedItems = sortedItems.slice(startIdx, endIdx);

  const handlePageSizeChange = useCallback((newSize: number) => {
    setPageSize(newSize);
    setCurrentPage(1);
    if (typeof window !== "undefined") {
      localStorage.setItem("{{name}}-page-size", String(newSize));
    }
  }, []);

  // Page number generation (max 5 with ellipsis)
  const pageNumbers = useMemo(() => {
    const pages: (number | "ellipsis")[] = [];
    if (totalPages <= 5) {
      for (let i = 1; i <= totalPages; i++) pages.push(i);
    } else {
      pages.push(1);
      if (currentPage > 3) pages.push("ellipsis");
      const start = Math.max(2, currentPage - 1);
      const end = Math.min(totalPages - 1, currentPage + 1);
      for (let i = start; i <= end; i++) pages.push(i);
      if (currentPage < totalPages - 2) pages.push("ellipsis");
      pages.push(totalPages);
    }
    return pages;
  }, [totalPages, currentPage]);

  {{#if views.table.groupBy}}
  // Group items by field
  const groupedItems = useMemo(() => {
    const groups = new Map<string, Array<Record<string, unknown>>>();
    for (const item of paginatedItems) {
      const key = String(item.{{views.table.groupBy}} ?? "Other");
      if (!groups.has(key)) groups.set(key, []);
      groups.get(key)!.push(item);
    }
    return groups;
  }, [paginatedItems]);
  {{/if}}

  // Column definitions from YAML
  const columns = [
    {{#if views.table.columns}}
    {{#each views.table.columns}}
    { field: "{{this.field}}", label: "{{this.field}}", type: "{{#if this.type}}{{this.type}}{{else}}string{{/if}}", sortable: {{#if this.sortable}}true{{else}}false{{/if}}, width: "{{#if this.width}}{{this.width}}{{else}}auto{{/if}}" },
    {{/each}}
    {{else}}
    {{#each fields}}
    {{#showOnView this "table"}}
    { field: "{{@key}}", label: "{{@key}}", type: "{{this.type}}", sortable: {{#if this.sortable}}true{{else}}true{{/if}}, width: "{{#if this.width}}{{this.width}}{{else}}auto{{/if}}" },
    {{/showOnView}}
    {{/each}}
    {{/if}}
  ];

  // Render cell by column type
  const renderCell = (item: Record<string, unknown>, col: typeof columns[0], isFirst: boolean) => {
    const value = item[col.field];

    switch (col.type) {
      case "string":
        return (
          <span className={`text-sm text-primary ${isFirst ? "font-semibold" : ""}`}>
            {value as string}
          </span>
        );
      case "text":
        return (
          <span className="text-sm text-primary truncate max-w-[300px] block">
            {value as string}
          </span>
        );
      case "number":
        return (
          <span className="text-sm text-right tabular-nums block">
            {value as number}
          </span>
        );
      case "boolean":
        return value ? (
          <Check className="h-4 w-4 text-green-500" />
        ) : (
          <X className="h-4 w-4 text-primary/20" />
        );
      case "enum":
        return (
          <span className="inline-flex items-center gap-1.5 text-xs">
            <span className="h-1.5 w-1.5 rounded-full bg-current" />
            <span>{value as string}</span>
          </span>
        );
      case "image":
        return value ? (
          <img
            src={value as string}
            alt=""
            className="h-8 w-8 rounded-md object-cover bg-muted"
          />
        ) : (
          <div className="h-8 w-8 rounded-md bg-muted" />
        );
      case "tag":
        return (
          <div className="flex flex-wrap gap-1">
            {(Array.isArray(value) ? value : []).map((tag, i) => (
              <span
                key={i}
                className="bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400 rounded-full px-2 py-0.5 text-xs font-semibold"
              >
                {tag as string}
              </span>
            ))}
          </div>
        );
      case "link":
        return value ? (
          <a
            href={value as string}
            target="_blank"
            rel="noopener noreferrer"
            className="text-primary underline-offset-4 hover:underline inline-flex items-center gap-1 text-sm"
            onClick={(e) => e.stopPropagation()}
          >
            Link <ExternalLink className="h-3 w-3" />
          </a>
        ) : null;
      case "timestamp":
        return (
          <span className="text-xs text-muted-foreground">
            {value ? new Date(value as number).toLocaleDateString() : ""}
          </span>
        );
      default:
        return (
          <span className={`text-sm text-primary ${isFirst ? "font-semibold" : ""}`}>
            {String(value ?? "")}
          </span>
        );
    }
  };

  const getWidthStyle = (width: string) => {
    if (width === "auto") return undefined;
    const px = WIDTH_MAP[width];
    return px ? { width: `${px}px`, minWidth: `${px}px` } : undefined;
  };

  // Loading skeleton
  if (isLoading && items.length === 0) {
    return (
      <div className="rounded-lg border border-border bg-card shadow-card overflow-hidden">
        <div className="bg-surface-secondary px-6 py-4">
          <div className="flex items-center gap-4">
            {Array.from({ length: 4 }).map((_, i) => (
              <div key={i} className="h-3 rounded bg-muted animate-pulse" style=\{{ width: `${[30, 15, 15, 10][i]}%` }} />
            ))}
          </div>
        </div>
        {Array.from({ length: 5 }).map((_, i) => (
          <div key={i} className="flex items-center gap-4 px-6 py-4 border-b border-border last:border-b-0">
            <div className="h-4 w-[30%] rounded bg-muted animate-pulse" />
            <div className="h-4 w-[15%] rounded bg-muted animate-pulse" />
            <div className="h-4 w-[15%] rounded bg-muted animate-pulse" />
            <div className="h-4 w-[10%] rounded bg-muted animate-pulse" />
          </div>
        ))}
      </div>
    );
  }

  // Empty state
  if (!isLoading && items.length === 0) {
    return (
      <div className="rounded-lg border border-border bg-card shadow-card overflow-hidden">
        <table className="w-full">
          <thead className="bg-surface-secondary">
            <tr>
              {columns.map((col, i) => (
                <th
                  key={col.field}
                  className={`px-4 py-4 text-left text-xs font-semibold uppercase tracking-wider text-muted-foreground whitespace-nowrap ${i === 0 ? "pl-6" : ""}`}
                  style={getWidthStyle(col.width)}
                >
                  {col.label}
                </th>
              ))}
              <th className="pr-6 w-12" />
            </tr>
          </thead>
          <tbody>
            <tr>
              <td colSpan={columns.length + 1}>
                <{{pascalCase name}}EmptyState variant="noData" icon={Table2} />
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    );
  }

  const renderRow = (item: Record<string, unknown>) => (
    <tr
      key={item._id as string}
      className="group {{#ifEq views.table.design 'striped'}}even:bg-surface-secondary {{/ifEq}}hover:bg-muted/30 transition-colors duration-150 cursor-pointer border-b border-border last:border-b-0"
      onClick={() => onRowClick?.(item)}
    >
      {columns.map((col, i) => (
        <td
          key={col.field}
          className={`px-4 py-4 text-sm text-primary whitespace-nowrap ${i === 0 ? "pl-6" : ""}`}
          style={getWidthStyle(col.width)}
        >
          {renderCell(item, col, i === 0)}
        </td>
      ))}
      <td className="pr-6">
        <div className="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
          <Button
            variant="ghost"
            size="icon"
            className="h-7 w-7"
            onClick={(e) => {
              e.stopPropagation();
              onEdit?.(item);
            }}
          >
            <Pencil className="h-3.5 w-3.5" />
          </Button>
          <Button
            variant="ghost"
            size="icon"
            className="h-7 w-7 text-destructive"
            onClick={(e) => {
              e.stopPropagation();
              onDelete?.(item);
            }}
          >
            <Trash2 className="h-3.5 w-3.5" />
          </Button>
        </div>
      </td>
    </tr>
  );

  return (
    <div className="rounded-lg border border-border bg-card shadow-card overflow-hidden">
      {/* @generated-start table-content */}
      <table className="w-full">
        <thead className="bg-surface-secondary">
          <tr>
            {columns.map((col, i) => (
              <th
                key={col.field}
                className={`px-4 py-4 text-left text-xs font-semibold uppercase tracking-wider text-muted-foreground whitespace-nowrap ${i === 0 ? "pl-6" : ""} ${col.sortable ? "cursor-pointer hover:text-primary transition-colors" : ""}`}
                style={getWidthStyle(col.width)}
                onClick={col.sortable ? () => handleSort(col.field) : undefined}
              >
                <span className="inline-flex items-center gap-1">
                  {col.label}
                  {col.sortable && sortColumn === col.field && (
                    sortDirection === "asc" ? (
                      <ChevronUp className="h-3 w-3 text-primary" />
                    ) : (
                      <ChevronDown className="h-3 w-3 text-primary" />
                    )
                  )}
                  {col.sortable && sortColumn !== col.field && (
                    <ChevronsUpDown className="h-3 w-3 opacity-0 group-hover:opacity-50" />
                  )}
                </span>
              </th>
            ))}
            <th className="pr-6 w-12" />
          </tr>
        </thead>

        <tbody>
          {{#if views.table.groupBy}}
          {Array.from(groupedItems.entries()).map(([groupKey, groupItems]) => (
            <Fragment key={groupKey}>
              {/* Group header */}
              <tr>
                <td
                  colSpan={columns.length + 1}
                  className="cursor-pointer select-none"
                  onClick={() => toggleGroup(groupKey)}
                >
                  <div className="flex items-center gap-2 bg-surface-secondary px-6 py-2 hover:bg-muted/50 transition-colors">
                    <ChevronRight
                      className={`h-4 w-4 text-muted-foreground transition-transform duration-200 ${
                        !collapsedGroups.has(groupKey) ? "rotate-90" : ""
                      }`}
                    />
                    <span className="text-xs font-semibold uppercase tracking-wider text-muted-foreground">
                      {groupKey}
                    </span>
                    <span className="text-xs text-muted-foreground/60 ml-1">
                      ({groupItems.length})
                    </span>
                  </div>
                </td>
              </tr>

              {/* Group rows */}
              {!collapsedGroups.has(groupKey) &&
                groupItems.map((item) => renderRow(item))}
            </Fragment>
          ))}
          {{else}}
          {paginatedItems.map((item) => renderRow(item))}
          {{/if}}
        </tbody>
      </table>
      {/* @generated-end table-content */}

      {/* Pagination footer */}
      <div className="flex items-center justify-between px-6 py-4 border-t border-border bg-surface-secondary">
        {/* Showing count */}
        <span className="text-xs text-muted-foreground">
          Showing {startIdx + 1}-{Math.min(endIdx, totalCount || sortedItems.length)} of {totalCount || sortedItems.length}
        </span>

        {/* Page size selector */}
        <div className="flex items-center gap-2">
          <span className="text-xs text-muted-foreground">Rows per page</span>
          <select
            className="h-8 w-16 text-xs rounded border border-border bg-card px-1"
            value={pageSize}
            onChange={(e) => handlePageSizeChange(Number(e.target.value))}
          >
            <option value={10}>10</option>
            <option value={20}>20</option>
            <option value={50}>50</option>
            <option value={100}>100</option>
          </select>
        </div>

        {/* Page navigation */}
        <div className="flex items-center gap-1">
          <Button
            variant="ghost"
            size="sm"
            disabled={currentPage === 1}
            onClick={() => setCurrentPage((p) => Math.max(1, p - 1))}
          >
            <ChevronLeft className="h-4 w-4" />
          </Button>

          {pageNumbers.map((page, i) =>
            page === "ellipsis" ? (
              <span key={`ellipsis-${i}`} className="px-1 text-xs text-muted-foreground">
                ...
              </span>
            ) : (
              <button
                key={page}
                type="button"
                className={`px-2.5 py-1 text-xs rounded-md transition-colors ${
                  currentPage === page
                    ? "bg-primary text-primary-foreground"
                    : "hover:bg-muted"
                }`}
                onClick={() => setCurrentPage(page)}
              >
                {page}
              </button>
            ),
          )}

          <Button
            variant="ghost"
            size="sm"
            disabled={currentPage === totalPages}
            onClick={() => setCurrentPage((p) => Math.min(totalPages, p + 1))}
          >
            <ChevronRight className="h-4 w-4" />
          </Button>
        </div>
      </div>
    </div>
  );
}
{{!-- @generated-end table-view --}}

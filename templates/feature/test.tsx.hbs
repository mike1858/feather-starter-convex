// -- Form submission ----------------------------------------------------------

{{#if operations.create}}
test("inline form creates a {{lowerCase label}}", async ({ client }) => {
  renderWithRouter(<{{pascalCase name}}Page />, client);

  const user = userEvent.setup();

  await waitFor(() => {
    expect(screen.getByPlaceholderText(/add {{lowerCase label}}/i)).toBeInTheDocument();
  });

  const input = screen.getByPlaceholderText(/add {{lowerCase label}}/i);
  await user.type(input, "New {{lowerCase label}} from form");
  await user.click(screen.getByRole("button", { name: /add/i }));

  await waitFor(async () => {
    const items = await client.query({{{apiPath name}}}.queries.list, {});
    expect(items.some((item: any) => {
      const title = item.title || item.name;
      return title === "New {{lowerCase label}} from form";
    })).toBe(true);
  });
});
{{/if}}

// -- Status badge -------------------------------------------------------------

{{#each fields}}
{{#if transitions}}
test("status badge advances status on click", async ({
  client,
  testClient,
  userId,
}) => {
  await testClient.run(async (ctx: any) => {
    await ctx.db.insert("{{../name}}", {
      {{#each ../fields}}
      {{#ifEq @key "title"}}title: "Status test",{{/ifEq}}
      {{#ifEq @key "name"}}name: "Status test",{{/ifEq}}
      {{#ifEq type "string"}}{{#unless (eq @key "title")}}{{#unless (eq @key "name")}}{{@key}}: "test",{{/unless}}{{/unless}}{{/ifEq}}
      {{#ifEq type "text"}}{{@key}}: "",{{/ifEq}}
      {{#ifEq type "boolean"}}{{@key}}: {{default}},{{/ifEq}}
      {{#ifEq type "number"}}{{@key}}: 0,{{/ifEq}}
      {{#ifEq type "enum"}}{{@key}}: "{{firstValue values}}",{{/ifEq}}
      {{/each}}
      {{#if ../timestamps}}
      createdAt: Date.now(),
      {{/if}}
      userId,
    });
  });

  renderWithRouter(<{{pascalCase ../name}}Page />, client);

  const user = userEvent.setup();

  await waitFor(() => {
    expect(screen.getByText("Status test")).toBeInTheDocument();
  });

  const firstStatus = "{{firstValue values}}";
  expect(screen.getByText("{{sentenceCase (firstValue values)}}")).toBeInTheDocument();

  await user.click(screen.getByText("{{sentenceCase (firstValue values)}}"));

  await waitFor(async () => {
    const items = await client.query({{{apiPath ../name}}}.queries.list, {});
    expect(items[0].{{@key}}).not.toBe(firstStatus);
  });
});
{{/if}}
{{/each}}

// -- Delete -------------------------------------------------------------------

{{#if operations.delete}}
test("delete button removes {{lowerCase label}}", async ({
  client,
  testClient,
  userId,
}) => {
  await testClient.run(async (ctx: any) => {
    await ctx.db.insert("{{name}}", {
      {{#each fields}}
      {{#ifEq @key "title"}}title: "Delete me",{{/ifEq}}
      {{#ifEq @key "name"}}name: "Delete me",{{/ifEq}}
      {{#ifEq type "string"}}{{#unless (eq @key "title")}}{{#unless (eq @key "name")}}{{@key}}: "test",{{/unless}}{{/unless}}{{/ifEq}}
      {{#ifEq type "text"}}{{@key}}: "",{{/ifEq}}
      {{#ifEq type "boolean"}}{{@key}}: {{default}},{{/ifEq}}
      {{#ifEq type "number"}}{{@key}}: 0,{{/ifEq}}
      {{#ifEq type "enum"}}{{@key}}: "{{firstValue values}}",{{/ifEq}}
      {{/each}}
      {{#if timestamps}}
      createdAt: Date.now(),
      {{/if}}
      userId,
    });
  });

  renderWithRouter(<{{pascalCase name}}Page />, client);

  const user = userEvent.setup();

  await waitFor(() => {
    expect(screen.getByText("Delete me")).toBeInTheDocument();
  });

  // First click shows confirmation (double-check pattern)
  const itemRow = screen.getByText("Delete me").closest("div.group");
  const deleteButton = itemRow!.querySelector("button:last-child")!;
  await user.click(deleteButton);

  await waitFor(() => {
    expect(screen.getByText("Delete?")).toBeInTheDocument();
  });

  // Second click confirms deletion
  await user.click(screen.getByText("Delete?"));

  await waitFor(async () => {
    const items = await client.query({{{apiPath name}}}.queries.list, {});
    expect(items).toHaveLength(0);
  });
});
{{/if}}


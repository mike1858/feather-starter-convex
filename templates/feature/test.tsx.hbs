// Test Matrix: {{pascalCase name}}Page
// | # | State               | Approach    | What to verify                                         |
// |---|---------------------|-------------|--------------------------------------------------------|
// | 1 | Empty list          | Integration | empty state message, create form visible               |
// | 2 | With data           | Integration | {{lowerCase label}} items rendered                     |
{{#if operations.create}}
// | 3 | Create {{lowerCase label}} | Integration | form submit creates record, backend updated     |
{{/if}}
{{#each fields}}
{{#if transitions}}
// | 4 | Status badge click  | Integration | advances {{@key}} on click                             |
{{/if}}
{{/each}}
{{#if operations.delete}}
// | 5 | Delete {{lowerCase label}} | Integration | double-check pattern, then record removed       |
{{/if}}

// @generated-start imports
import { describe, expect } from "vitest";
import { screen, waitFor } from "@testing-library/react";
import userEvent from "@testing-library/user-event";
import { test } from "@cvx/test.setup";
import { api } from "~/convex/_generated/api";
import { renderWithRouter } from "@/test-helpers";
import { {{pascalCase name}}Page } from "./";
// @generated-end imports
// @custom-start imports
// @custom-end imports

describe("{{pascalCase name}}Page", () => {
  test("shows empty state with create form when no {{lowerCase labelPlural}}", async ({
    client,
  }) => {
    renderWithRouter(<{{pascalCase name}}Page />, client);

    expect(
      await screen.findByText("No {{lowerCase labelPlural}} yet. Create one above!"),
    ).toBeInTheDocument();
{{#if operations.create}}
    expect(screen.getByPlaceholderText(/add {{lowerCase label}}/i)).toBeInTheDocument();
    expect(screen.getByRole("button", { name: /add/i })).toBeInTheDocument();
{{/if}}
  });

  test("renders seeded {{lowerCase label}} items", async ({
    client,
    testClient,
    userId,
  }) => {
    await testClient.run(async (ctx: any) => {
      await ctx.db.insert("{{name}}", {
        {{#each fields}}
        {{#ifEq @key "title"}}title: "First {{sentenceCase ../name}}",{{/ifEq}}
        {{#ifEq @key "name"}}name: "First {{sentenceCase ../name}}",{{/ifEq}}
        {{#ifEq type "string"}}{{#unless (eq @key "title")}}{{#unless (eq @key "name")}}{{@key}}: "test",{{/unless}}{{/unless}}{{/ifEq}}
        {{#ifEq type "text"}}{{@key}}: "test description",{{/ifEq}}
        {{#ifEq type "boolean"}}{{@key}}: {{default}},{{/ifEq}}
        {{#ifEq type "number"}}{{@key}}: 0,{{/ifEq}}
        {{#ifEq type "enum"}}{{@key}}: "{{firstValue values}}",{{/ifEq}}
        {{/each}}
        {{#if timestamps}}
        createdAt: Date.now(),
        {{/if}}
        userId,
        {{#if behaviors.assignable}}assigneeId: userId,{{/if}}
        {{#if behaviors.orderable}}position: 1000,{{/if}}
      });
      await ctx.db.insert("{{name}}", {
        {{#each fields}}
        {{#ifEq @key "title"}}title: "Second {{sentenceCase ../name}}",{{/ifEq}}
        {{#ifEq @key "name"}}name: "Second {{sentenceCase ../name}}",{{/ifEq}}
        {{#ifEq type "string"}}{{#unless (eq @key "title")}}{{#unless (eq @key "name")}}{{@key}}: "test",{{/unless}}{{/unless}}{{/ifEq}}
        {{#ifEq type "text"}}{{@key}}: "test description",{{/ifEq}}
        {{#ifEq type "boolean"}}{{@key}}: {{default}},{{/ifEq}}
        {{#ifEq type "number"}}{{@key}}: 0,{{/ifEq}}
        {{#ifEq type "enum"}}{{@key}}: "{{firstValue values}}",{{/ifEq}}
        {{/each}}
        {{#if timestamps}}
        createdAt: Date.now(),
        {{/if}}
        userId,
        {{#if behaviors.assignable}}assigneeId: userId,{{/if}}
        {{#if behaviors.orderable}}position: 2000,{{/if}}
      });
    });

    renderWithRouter(<{{pascalCase name}}Page />, client);

    expect(await screen.findByText("First {{sentenceCase name}}")).toBeInTheDocument();
    expect(screen.getByText("Second {{sentenceCase name}}")).toBeInTheDocument();
  });

{{#if operations.create}}
  test("creates {{lowerCase label}} via form submission", async ({ client }) => {
    renderWithRouter(<{{pascalCase name}}Page />, client);

    const user = userEvent.setup();

    const input = await screen.findByPlaceholderText(/add {{lowerCase label}}/i);
    await user.type(input, "New {{lowerCase label}} from form");
    await user.click(screen.getByRole("button", { name: /add/i }));

    await waitFor(async () => {
      const items = await client.query({{{apiPath name}}}.queries.list, {});
      expect(items.some((item: any) => {
        const title = item.title || item.name;
        return title === "New {{lowerCase label}} from form";
      })).toBe(true);
    });
  });
{{/if}}

{{#each fields}}
{{#if transitions}}
  test("advances {{@key}} on badge click", async ({
    client,
    testClient,
    userId,
  }) => {
    await testClient.run(async (ctx: any) => {
      await ctx.db.insert("{{../name}}", {
        {{#each ../fields}}
        {{#ifEq @key "title"}}title: "Status test",{{/ifEq}}
        {{#ifEq @key "name"}}name: "Status test",{{/ifEq}}
        {{#ifEq type "string"}}{{#unless (eq @key "title")}}{{#unless (eq @key "name")}}{{@key}}: "test",{{/unless}}{{/unless}}{{/ifEq}}
        {{#ifEq type "text"}}{{@key}}: "",{{/ifEq}}
        {{#ifEq type "boolean"}}{{@key}}: {{default}},{{/ifEq}}
        {{#ifEq type "number"}}{{@key}}: 0,{{/ifEq}}
        {{#ifEq type "enum"}}{{@key}}: "{{firstValue values}}",{{/ifEq}}
        {{/each}}
        {{#if ../timestamps}}
        createdAt: Date.now(),
        {{/if}}
        userId,
        {{#if ../behaviors.assignable}}assigneeId: userId,{{/if}}
        {{#if ../behaviors.orderable}}position: 1000,{{/if}}
      });
    });

    renderWithRouter(<{{pascalCase ../name}}Page />, client);

    const user = userEvent.setup();

    expect(await screen.findByText("Status test")).toBeInTheDocument();
    expect(screen.getByText("{{sentenceCase (firstValue values)}}")).toBeInTheDocument();

    await user.click(screen.getByText("{{sentenceCase (firstValue values)}}"));

    await waitFor(async () => {
      const items = await client.query({{{apiPath ../name}}}.queries.list, {});
      expect(items[0].{{@key}}).not.toBe("{{firstValue values}}");
    });
  });
{{/if}}
{{/each}}

{{#if operations.delete}}
  test("deletes {{lowerCase label}} with double-check confirmation", async ({
    client,
    testClient,
    userId,
  }) => {
    await testClient.run(async (ctx: any) => {
      await ctx.db.insert("{{name}}", {
        {{#each fields}}
        {{#ifEq @key "title"}}title: "Delete me",{{/ifEq}}
        {{#ifEq @key "name"}}name: "Delete me",{{/ifEq}}
        {{#ifEq type "string"}}{{#unless (eq @key "title")}}{{#unless (eq @key "name")}}{{@key}}: "test",{{/unless}}{{/unless}}{{/ifEq}}
        {{#ifEq type "text"}}{{@key}}: "",{{/ifEq}}
        {{#ifEq type "boolean"}}{{@key}}: {{default}},{{/ifEq}}
        {{#ifEq type "number"}}{{@key}}: 0,{{/ifEq}}
        {{#ifEq type "enum"}}{{@key}}: "{{firstValue values}}",{{/ifEq}}
        {{/each}}
        {{#if timestamps}}
        createdAt: Date.now(),
        {{/if}}
        userId,
        {{#if behaviors.assignable}}assigneeId: userId,{{/if}}
        {{#if behaviors.orderable}}position: 1000,{{/if}}
      });
    });

    renderWithRouter(<{{pascalCase name}}Page />, client);

    const user = userEvent.setup();

    expect(await screen.findByText("Delete me")).toBeInTheDocument();

    // First click shows confirmation
    const taskRow = screen
      .getByText("Delete me")
      .closest("div.flex.items-center");
    const buttons = taskRow!.querySelectorAll("button");
    const trashButton = buttons[buttons.length - 1];
    await user.click(trashButton!);

    expect(await screen.findByText("Are you sure?")).toBeInTheDocument();

    // Second click confirms deletion
    await user.click(screen.getByText("Are you sure?"));

    await waitFor(async () => {
      const items = await client.query({{{apiPath name}}}.queries.list, {});
      expect(items).toHaveLength(0);
    });
  });
{{/if}}
});


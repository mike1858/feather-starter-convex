{{!-- @generated-start table-panel --}}
import { useState, useMemo, useCallback } from "react";
{{#unless readonly}}
import { useQuery, useMutation } from "convex/react";
{{else}}
import { useQuery } from "convex/react";
{{/unless}}
import { api } from "@cvx/_generated/api";
import { {{#if inline}}{{#unless readonly}}Plus, {{/unless}}{{/if}}{{#unless readonly}}Pencil, Trash2, {{/unless}}ChevronUp, ChevronDown, ChevronsUpDown } from "lucide-react";
import { Button } from "@/ui/button";
import type { Id } from "@cvx/_generated/dataModel";

interface {{sourcePascal}}TablePanelProps {
  parentId: Id<"{{foreignKey}}">;
}

type SortDirection = "asc" | "desc";

function toTitleCase(str: string): string {
  return str
    .replace(/([A-Z])/g, " $1")
    .replace(/[-_]/g, " ")
    .replace(/^\s+/, "")
    .replace(/\b\w/g, (c) => c.toUpperCase());
}

const COLUMNS = [
  {{#each columns}}
  { field: "{{this}}", label: toTitleCase("{{this}}") },
  {{/each}}
];

export function {{sourcePascal}}TablePanel({
  parentId,
}: {{sourcePascal}}TablePanelProps) {
  const [sortColumn, setSortColumn] = useState<string | null>(null);
  const [sortDirection, setSortDirection] = useState<SortDirection>("asc");
  const [currentPage, setCurrentPage] = useState(1);
  const PAGE_SIZE = 20;

  const items = useQuery(api.{{source}}.queries.listByParent, { parentId });

  {{#unless readonly}}
  const createItem = useMutation(api.{{source}}.mutations.create);
  const removeItem = useMutation(api.{{source}}.mutations.remove);
  {{/unless}}

  const handleSort = useCallback((column: string) => {
    setSortColumn((prev) => {
      if (prev === column) {
        setSortDirection((d) => (d === "asc" ? "desc" : "asc"));
        return column;
      }
      setSortDirection("asc");
      return column;
    });
  }, []);

  const sortedItems = useMemo(() => {
    if (!items || !sortColumn) return items ?? [];
    return [...items].sort((a, b) => {
      const aVal = (a as Record<string, unknown>)[sortColumn];
      const bVal = (b as Record<string, unknown>)[sortColumn];
      if (aVal == null && bVal == null) return 0;
      if (aVal == null) return 1;
      if (bVal == null) return -1;
      const cmp = String(aVal).localeCompare(String(bVal), undefined, { numeric: true });
      return sortDirection === "asc" ? cmp : -cmp;
    });
  }, [items, sortColumn, sortDirection]);

  const totalPages = Math.ceil(sortedItems.length / PAGE_SIZE);
  const startIdx = (currentPage - 1) * PAGE_SIZE;
  const paginatedItems = sortedItems.slice(startIdx, startIdx + PAGE_SIZE);

  const handleRemove = async (itemId: string) => {
    {{#unless readonly}}
    await removeItem({ {{source}}Id: itemId as Id<"{{source}}"> });
    {{/unless}}
  };

  return (
    <div className="rounded-lg border border-border bg-card shadow-card overflow-hidden">
      {/* Panel header */}
      <div className="flex items-center justify-between px-4 py-3 border-b border-border">
        <h3 className="text-sm font-semibold text-primary">{{sourcePlural}}</h3>
        {{#unless readonly}}
        {{#if inline}}
        <Button
          variant="ghost"
          size="sm"
          className="h-7 gap-1.5 text-xs text-muted-foreground hover:text-primary"
        >
          <Plus className="h-3.5 w-3.5" />
          Add
        </Button>
        {{/if}}
        {{/unless}}
      </div>

      {/* Loading skeleton */}
      {items === undefined && (
        <div className="divide-y divide-border">
          {Array.from({ length: 3 }).map((_, i) => (
            <div key={i} className="flex items-center gap-4 px-4 py-3">
              {COLUMNS.map((col) => (
                <div key={col.field} className="flex-1 h-4 rounded bg-muted animate-pulse" />
              ))}
            </div>
          ))}
        </div>
      )}

      {/* Empty state */}
      {items?.length === 0 && (
        <div className="px-4 py-8 text-center">
          <p className="text-sm text-muted-foreground">No {{sourcePlural}} yet</p>
          {{#unless readonly}}
          {{#if inline}}
          <Button
            variant="ghost"
            size="sm"
            className="mt-2 text-xs gap-1.5"
          >
            <Plus className="h-3.5 w-3.5" />
            Add the first one
          </Button>
          {{/if}}
          {{/unless}}
        </div>
      )}

      {/* Table */}
      {items && items.length > 0 && (
        <div className="overflow-x-auto">
          <table className="w-full">
            <thead className="bg-muted/40">
              <tr>
                {COLUMNS.map((col) => (
                  <th
                    key={col.field}
                    className="px-4 py-2.5 text-left text-xs font-semibold uppercase tracking-wider text-muted-foreground cursor-pointer hover:text-primary transition-colors whitespace-nowrap"
                    onClick={() => handleSort(col.field)}
                  >
                    <span className="inline-flex items-center gap-1">
                      {col.label}
                      {sortColumn === col.field ? (
                        sortDirection === "asc" ? (
                          <ChevronUp className="h-3 w-3 text-primary" />
                        ) : (
                          <ChevronDown className="h-3 w-3 text-primary" />
                        )
                      ) : (
                        <ChevronsUpDown className="h-3 w-3 opacity-0 group-hover:opacity-50" />
                      )}
                    </span>
                  </th>
                ))}
                {{#unless readonly}}
                <th className="w-16 px-4 py-2.5" />
                {{/unless}}
              </tr>
            </thead>
            <tbody className="divide-y divide-border">
              {paginatedItems.map((item) => (
                <tr
                  key={item._id}
                  className="group hover:bg-muted/30 transition-colors"
                >
                  {COLUMNS.map((col, i) => {
                    const val = (item as Record<string, unknown>)[col.field];
                    return (
                      <td
                        key={col.field}
                        className={`px-4 py-3 text-sm text-primary whitespace-nowrap ${i === 0 ? "font-medium" : ""}`}
                      >
                        {typeof val === "boolean" ? (
                          <span className={`inline-flex h-4 w-4 items-center justify-center rounded-sm border ${val ? "bg-primary border-primary" : "border-border"}`}>
                            {val && (
                              <svg viewBox="0 0 12 12" className="h-3 w-3 text-primary-foreground" fill="none" stroke="currentColor" strokeWidth={2}>
                                <polyline points="2,6 5,9 10,3" />
                              </svg>
                            )}
                          </span>
                        ) : val == null ? (
                          <span className="text-muted-foreground/40 italic text-xs">—</span>
                        ) : (
                          <span>{String(val)}</span>
                        )}
                      </td>
                    );
                  })}
                  {{#unless readonly}}
                  <td className="px-4 py-3">
                    <div className="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                      <Button
                        variant="ghost"
                        size="icon"
                        className="h-6 w-6"
                        aria-label="Edit"
                      >
                        <Pencil className="h-3 w-3" />
                      </Button>
                      <Button
                        variant="ghost"
                        size="icon"
                        className="h-6 w-6 text-destructive"
                        onClick={() => handleRemove(item._id)}
                        aria-label="Delete"
                      >
                        <Trash2 className="h-3 w-3" />
                      </Button>
                    </div>
                  </td>
                  {{/unless}}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}

      {/* Pagination */}
      {sortedItems.length > PAGE_SIZE && (
        <div className="flex items-center justify-between px-4 py-3 border-t border-border bg-muted/20">
          <span className="text-xs text-muted-foreground">
            {startIdx + 1}–{Math.min(startIdx + PAGE_SIZE, sortedItems.length)} of {sortedItems.length}
          </span>
          <div className="flex items-center gap-1">
            <Button
              variant="ghost"
              size="sm"
              className="h-7 text-xs"
              disabled={currentPage === 1}
              onClick={() => setCurrentPage((p) => Math.max(1, p - 1))}
            >
              Previous
            </Button>
            <Button
              variant="ghost"
              size="sm"
              className="h-7 text-xs"
              disabled={currentPage === totalPages}
              onClick={() => setCurrentPage((p) => Math.min(totalPages, p + 1))}
            >
              Next
            </Button>
          </div>
        </div>
      )}
    </div>
  );
}
{{!-- @generated-end table-panel --}}

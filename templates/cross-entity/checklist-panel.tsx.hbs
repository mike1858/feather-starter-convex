{{!-- @generated-start checklist-panel --}}
import { useState } from "react";
{{#unless readonly}}
import { useQuery, useMutation } from "convex/react";
{{else}}
import { useQuery } from "convex/react";
{{/unless}}
import { api } from "@cvx/_generated/api";
import { GripVertical{{#unless readonly}}, Plus, Trash2{{/unless}} } from "lucide-react";
import { Button } from "@/ui/button";
import type { Id } from "@cvx/_generated/dataModel";

interface {{sourcePascal}}ChecklistPanelProps {
  parentId: Id<"{{foreignKey}}">;
}

export function {{sourcePascal}}ChecklistPanel({
  parentId,
}: {{sourcePascal}}ChecklistPanelProps) {
  const [newItemTitle, setNewItemTitle] = useState("");
  const [isAdding, setIsAdding] = useState(false);

  const items = useQuery(api.{{source}}.queries.listByParent, { parentId });

  {{#unless readonly}}
  const createItem = useMutation(api.{{source}}.mutations.create);
  const updateItem = useMutation(api.{{source}}.mutations.update);
  const removeItem = useMutation(api.{{source}}.mutations.remove);
  {{/unless}}

  const handleToggle = async (itemId: string, completed: boolean) => {
    {{#unless readonly}}
    await updateItem({ {{source}}Id: itemId as Id<"{{source}}">, completed: !completed });
    {{/unless}}
  };

  const handleAdd = async () => {
    if (!newItemTitle.trim()) return;
    {{#unless readonly}}
    await createItem({ title: newItemTitle.trim(), {{foreignKey}}: parentId });
    {{/unless}}
    setNewItemTitle("");
    setIsAdding(false);
  };

  const handleRemove = async (itemId: string) => {
    {{#unless readonly}}
    await removeItem({ {{source}}Id: itemId as Id<"{{source}}"> });
    {{/unless}}
  };

  return (
    <div className="rounded-lg border border-border bg-card shadow-card">
      {/* Panel header */}
      <div className="flex items-center justify-between px-4 py-3 border-b border-border">
        <h3 className="text-sm font-semibold text-primary">{{sourcePlural}}</h3>
        {{#unless readonly}}
        {{#if inline}}
        <Button
          variant="ghost"
          size="sm"
          className="h-7 gap-1.5 text-xs text-muted-foreground hover:text-primary"
          onClick={() => setIsAdding(true)}
        >
          <Plus className="h-3.5 w-3.5" />
          Add
        </Button>
        {{/if}}
        {{/unless}}
      </div>

      {/* Item list */}
      <div className="divide-y divide-border">
        {items === undefined && (
          <div className="px-4 py-8 text-center">
            <div className="h-4 w-32 rounded bg-muted animate-pulse mx-auto" />
          </div>
        )}

        {items?.length === 0 && (
          <div className="px-4 py-8 text-center">
            <p className="text-sm text-muted-foreground">No {{sourcePlural}} yet</p>
            {{#unless readonly}}
            {{#if inline}}
            <Button
              variant="ghost"
              size="sm"
              className="mt-2 text-xs gap-1.5"
              onClick={() => setIsAdding(true)}
            >
              <Plus className="h-3.5 w-3.5" />
              Add the first one
            </Button>
            {{/if}}
            {{/unless}}
          </div>
        )}

        {items?.map((item) => (
          <div
            key={item._id}
            className="group flex items-center gap-3 px-4 py-3 hover:bg-muted/30 transition-colors"
          >
            {/* Drag handle */}
            <button
              type="button"
              className="p-0.5 cursor-grab text-primary/20 hover:text-primary/50 opacity-0 group-hover:opacity-100 transition-opacity"
              aria-label="Reorder"
            >
              <GripVertical className="h-4 w-4" />
            </button>

            {/* Checkbox */}
            <button
              type="button"
              className={`h-4 w-4 shrink-0 rounded border-2 transition-colors ${
                item.completed
                  ? "bg-primary border-primary"
                  : "border-border hover:border-primary/60"
              }`}
              onClick={() => handleToggle(item._id, item.completed ?? false)}
              aria-label={item.completed ? "Mark incomplete" : "Mark complete"}
            >
              {item.completed && (
                <svg
                  viewBox="0 0 12 12"
                  className="h-full w-full text-primary-foreground"
                  fill="none"
                  stroke="currentColor"
                  strokeWidth={2}
                >
                  <polyline points="2,6 5,9 10,3" />
                </svg>
              )}
            </button>

            {/* Title */}
            <span
              className={`flex-1 text-sm truncate ${
                item.completed ? "line-through text-muted-foreground" : "text-primary"
              }`}
            >
              {item.title as string}
            </span>

            {/* Delete action */}
            {{#unless readonly}}
            <button
              type="button"
              className="p-1 text-muted-foreground hover:text-destructive opacity-0 group-hover:opacity-100 transition-all"
              onClick={() => handleRemove(item._id)}
              aria-label="Delete"
            >
              <Trash2 className="h-3.5 w-3.5" />
            </button>
            {{/unless}}
          </div>
        ))}
      </div>

      {/* Inline add form */}
      {{#unless readonly}}
      {{#if inline}}
      {isAdding && (
        <div className="px-4 py-3 border-t border-border bg-muted/20">
          <div className="flex items-center gap-2">
            <input
              type="text"
              className="flex-1 h-8 rounded border border-input bg-background px-3 text-sm placeholder:text-muted-foreground focus:outline-none focus:ring-1 focus:ring-ring"
              placeholder="Enter title..."
              value={newItemTitle}
              onChange={(e) => setNewItemTitle(e.target.value)}
              onKeyDown={(e) => {
                if (e.key === "Enter") void handleAdd();
                if (e.key === "Escape") setIsAdding(false);
              }}
              autoFocus
            />
            <Button size="sm" className="h-8 text-xs" onClick={() => void handleAdd()}>
              Add
            </Button>
            <Button
              variant="ghost"
              size="sm"
              className="h-8 text-xs"
              onClick={() => {
                setIsAdding(false);
                setNewItemTitle("");
              }}
            >
              Cancel
            </Button>
          </div>
        </div>
      )}
      {{/if}}
      {{/unless}}
    </div>
  );
}
{{!-- @generated-end checklist-panel --}}

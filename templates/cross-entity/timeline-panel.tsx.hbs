{{!-- @generated-start timeline-panel --}}
import { useState } from "react";
{{#unless readonly}}
import { useQuery, useMutation } from "convex/react";
{{else}}
import { useQuery } from "convex/react";
{{/unless}}
import { api } from "@cvx/_generated/api";
import { Clock{{#unless readonly}}, Plus{{/unless}} } from "lucide-react";
import { Button } from "@/ui/button";
import type { Id } from "@cvx/_generated/dataModel";

interface {{sourcePascal}}TimelinePanelProps {
  parentId: Id<"{{foreignKey}}">;
}

function formatRelativeTime(timestamp: number): string {
  const now = Date.now();
  const diff = now - timestamp;
  const seconds = Math.floor(diff / 1000);
  const minutes = Math.floor(seconds / 60);
  const hours = Math.floor(minutes / 60);
  const days = Math.floor(hours / 24);

  if (days > 0) return `${days}d ago`;
  if (hours > 0) return `${hours}h ago`;
  if (minutes > 0) return `${minutes}m ago`;
  return "just now";
}

export function {{sourcePascal}}TimelinePanel({
  parentId,
}: {{sourcePascal}}TimelinePanelProps) {
  const [newEntryBody, setNewEntryBody] = useState("");
  const [isAdding, setIsAdding] = useState(false);

  const items = useQuery(api.{{source}}.queries.listByParent, { parentId });

  {{#unless readonly}}
  const createItem = useMutation(api.{{source}}.mutations.create);
  const removeItem = useMutation(api.{{source}}.mutations.remove);
  {{/unless}}

  const handleAdd = async () => {
    if (!newEntryBody.trim()) return;
    {{#unless readonly}}
    await createItem({ body: newEntryBody.trim(), {{foreignKey}}: parentId });
    {{/unless}}
    setNewEntryBody("");
    setIsAdding(false);
  };

  const handleRemove = async (itemId: string) => {
    {{#unless readonly}}
    await removeItem({ {{source}}Id: itemId as Id<"{{source}}"> });
    {{/unless}}
  };

  return (
    <div className="rounded-lg border border-border bg-card shadow-card">
      {/* Panel header */}
      <div className="flex items-center justify-between px-4 py-3 border-b border-border">
        <h3 className="text-sm font-semibold text-primary">{{sourcePlural}}</h3>
        {{#unless readonly}}
        {{#if inline}}
        <Button
          variant="ghost"
          size="sm"
          className="h-7 gap-1.5 text-xs text-muted-foreground hover:text-primary"
          onClick={() => setIsAdding(true)}
        >
          <Plus className="h-3.5 w-3.5" />
          Add
        </Button>
        {{/if}}
        {{/unless}}
      </div>

      {/* Inline add form at top */}
      {{#unless readonly}}
      {{#if inline}}
      {isAdding && (
        <div className="px-4 py-3 border-b border-border bg-muted/20">
          <div className="flex flex-col gap-2">
            <textarea
              className="w-full rounded border border-input bg-background px-3 py-2 text-sm placeholder:text-muted-foreground focus:outline-none focus:ring-1 focus:ring-ring resize-none"
              placeholder="Enter note..."
              rows={3}
              value={newEntryBody}
              onChange={(e) => setNewEntryBody(e.target.value)}
              onKeyDown={(e) => {
                if (e.key === "Enter" && e.metaKey) void handleAdd();
                if (e.key === "Escape") setIsAdding(false);
              }}
              autoFocus
            />
            <div className="flex items-center gap-2 justify-end">
              <Button
                variant="ghost"
                size="sm"
                className="h-7 text-xs"
                onClick={() => {
                  setIsAdding(false);
                  setNewEntryBody("");
                }}
              >
                Cancel
              </Button>
              <Button size="sm" className="h-7 text-xs" onClick={() => void handleAdd()}>
                Add Entry
              </Button>
            </div>
          </div>
        </div>
      )}
      {{/if}}
      {{/unless}}

      {/* Timeline entries */}
      <div className="px-4 py-3">
        {items === undefined && (
          <div className="py-6 text-center">
            <div className="h-4 w-32 rounded bg-muted animate-pulse mx-auto" />
          </div>
        )}

        {items?.length === 0 && (
          <div className="py-6 text-center">
            <Clock className="h-8 w-8 text-muted-foreground/30 mx-auto mb-2" />
            <p className="text-sm text-muted-foreground">No {{sourcePlural}} yet</p>
            {{#unless readonly}}
            {{#if inline}}
            <Button
              variant="ghost"
              size="sm"
              className="mt-2 text-xs gap-1.5"
              onClick={() => setIsAdding(true)}
            >
              <Plus className="h-3.5 w-3.5" />
              Add the first entry
            </Button>
            {{/if}}
            {{/unless}}
          </div>
        )}

        {items && items.length > 0 && (
          <div className="relative">
            {/* Vertical line */}
            <div className="absolute left-3 top-2 bottom-2 w-px border-l-2 border-gray-200" />

            <div className="flex flex-col gap-4">
              {items.map((item) => (
                <div key={item._id} className="relative flex items-start gap-4 group">
                  {/* Timeline dot */}
                  <div className="relative z-10 h-6 w-6 shrink-0 rounded-full bg-card border-2 border-gray-300 flex items-center justify-center">
                    <div className="h-2 w-2 rounded-full bg-gray-400" />
                  </div>

                  {/* Entry content */}
                  <div className="flex-1 min-w-0 pb-1">
                    <div className="flex items-start justify-between gap-2">
                      <div className="flex-1 min-w-0">
                        <p className="text-sm text-primary">
                          {item.body as string}
                        </p>
                        {/* Duration if present (work-logs) */}
                        {(item as Record<string, unknown>).timeMinutes !== undefined && (
                          <span className="mt-0.5 inline-flex items-center gap-1 text-xs text-muted-foreground">
                            <Clock className="h-3 w-3" />
                            {Math.floor(((item as Record<string, unknown>).timeMinutes as number) / 60)}h{" "}
                            {((item as Record<string, unknown>).timeMinutes as number) % 60}m
                          </span>
                        )}
                        {/* Event type badge if present (activity-logs) */}
                        {(item as Record<string, unknown>).eventType !== undefined && (
                          <span className="mt-0.5 inline-flex items-center rounded-full bg-muted px-2 py-0.5 text-xs font-medium text-muted-foreground">
                            {(item as Record<string, unknown>).eventType as string}
                          </span>
                        )}
                      </div>

                      <div className="flex items-center gap-1 shrink-0">
                        <span className="text-xs text-muted-foreground whitespace-nowrap">
                          {formatRelativeTime(item._creationTime)}
                        </span>
                        {{#unless readonly}}
                        <button
                          type="button"
                          className="p-1 text-muted-foreground hover:text-destructive opacity-0 group-hover:opacity-100 transition-all ml-1"
                          onClick={() => handleRemove(item._id)}
                          aria-label="Delete entry"
                        >
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            strokeWidth={2}
                            className="h-3.5 w-3.5"
                          >
                            <polyline points="3 6 5 6 21 6" />
                            <path d="M19 6l-1 14H6L5 6" />
                            <path d="M10 11v6" />
                            <path d="M14 11v6" />
                            <path d="M9 6V4h6v2" />
                          </svg>
                        </button>
                        {{/unless}}
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  );
}
{{!-- @generated-end timeline-panel --}}
